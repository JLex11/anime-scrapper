{
  "name": "anime-scrapper",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "bun --watch api/index.ts",
    "build": "bun build --target=bun --entrypoints api/index.ts --outdir ./public/api & bun run docs:build",
    "start": "bun run ./public/api/index.js",
    "test": "bun test",
    "test:endpoints": "bun run scripts/smokeEndpoints.ts",
    "lint": "bunx biome lint --write && bunx biome format --write",
    "analyze": "bun build --target=bun --entrypoints api/index.ts --analyze",
    "clean-cache": "rm -rf node_modules/.cache",
    "build:optimized": "NODE_ENV=production bun build --target=bun --minify --entrypoints api/index.ts --outdir ./public/api",
    "docs:dev": "bunx astro dev --root docs --host",
    "docs:build": "bunx astro build --root docs && rm -rf public/api-docs && mkdir -p public/api-docs && cp -a docs/dist/. public/api-docs/",
    "docs:preview": "bunx astro preview --root docs --host"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-s3": "^3.525.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@smithy/protocol-http": "^5.3.5",
    "@smithy/signature-v4": "^5.3.5",
    "@supabase/supabase-js": "2.89.0",
    "@types/compression": "^1.7.5",
    "compression": "^1.8.0",
    "cors": "2.8.5",
    "express": "5.2.1",
    "node-cache": "5.1.2",
    "supabase": "^2.22.12",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@aws-sdk/types": "3.957.0",
    "@biomejs/biome": "2.2.4",
    "@types/bun": "^1.2.12",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "^25.0.3",
    "@astrojs/mdx": "4.3.13",
    "astro": "5.16.6",
    "ts-standard": "^12.0.2",
    "typescript": "5.9.3"
  },
  "ts-standard": {
    "ignore": [
      "public"
    ]
  },
  "private": true
}
